---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: 'fountain' | 'monument' | 'artwork';
  accentColor: 'gold' | 'red' | 'blue';
}

const { title, description, href, icon, accentColor } = Astro.props;

const colorMap = {
  gold: {
    bg: 'bg-brand-gold',
    shadow: 'shadow-brutal-gold',
    hover: 'hover:bg-brand-gold/90',
  },
  red: {
    bg: 'bg-brand-red',
    shadow: 'shadow-brutal-red',
    hover: 'hover:bg-brand-red/90',
  },
  blue: {
    bg: 'bg-brand-blue',
    shadow: 'shadow-brutal-blue',
    hover: 'hover:bg-brand-blue/90',
  },
};

const colors = colorMap[accentColor];
---

<a href={href} class="group block">
  <article
    class={`border-3 border-black ${colors.bg} p-6 sm:p-8 transition-all duration-150 hover:-translate-x-1 hover:-translate-y-1 hover:shadow-brutal-lg`}
    style={`box-shadow: var(--shadow-brutal);`}
  >
    <!-- Icon -->
    <div class="mb-4">
      {icon === 'fountain' && (
        <svg class="w-12 h-12 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 3v1m0 16v1m-7-8H4m16 0h1M7.05 7.05l-.7-.7m12.02 12.02l-.7-.7M7.05 16.95l-.7.7M18.37 5.63l-.7.7M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
      )}
      {icon === 'monument' && (
        <svg class="w-12 h-12 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2m-16 0H3m9-16v16" />
        </svg>
      )}
      {icon === 'artwork' && (
        <svg class="w-12 h-12 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
        </svg>
      )}
    </div>

    <!-- Text -->
    <h3 class={`font-heading text-2xl sm:text-3xl font-bold uppercase tracking-wider mb-2 ${accentColor === 'blue' ? 'text-white' : 'text-black'}`}>
      {title}
    </h3>
    <p class={`text-sm leading-relaxed ${accentColor === 'blue' ? 'text-white/80' : 'text-black/70'}`}>
      {description}
    </p>

    <!-- Arrow -->
    <div class={`mt-4 font-heading font-bold text-sm uppercase tracking-wider flex items-center gap-2 ${accentColor === 'blue' ? 'text-white' : 'text-black'}`}>
      <span class="group-hover:translate-x-1 transition-transform">→</span>
    </div>
  </article>
</a>
