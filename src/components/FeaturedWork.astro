---
import ModelViewer from './ModelViewer.astro';
import { getWorkPath, useTranslations, type Lang } from '@/i18n/ui';
import { getCollection } from 'astro:content';
import { getAssetUrl } from '@/utils/assets';
import { marked } from 'marked';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get all works and pick one randomly at build time
const allWorks = await getCollection('works');
const worksWithModels = allWorks.filter((w) => w.data.model.glb);
const featured = worksWithModels.length > 0
  ? worksWithModels[Math.floor(Math.random() * worksWithModels.length)]
  : null;
const featuredDescriptionHtml = featured ? await marked.parse(featured.data.description[lang]) : '';
---

{featured && (
  <section class="py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold uppercase tracking-wider mb-8 text-center">
        {t('home.featured')}
      </h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <!-- 3D Viewer -->
        <div class="aspect-square">
          <ModelViewer
            src={getAssetUrl(featured.data.model.glb!)}
            iosSrc={featured.data.model.usdz ? getAssetUrl(featured.data.model.usdz) : undefined}
            alt={featured.data.title[lang]}
            poster={featured.data.poster ? getAssetUrl(featured.data.poster) : undefined}
            class="h-full"
          />
        </div>

        <!-- Info -->
        <div class="flex flex-col justify-center">
          <h3 class="font-heading text-2xl sm:text-3xl font-bold uppercase tracking-wider mb-4">
            {featured.data.title[lang]}
          </h3>
          <div class="prose text-lg leading-relaxed mb-6 text-black/70" set:html={featuredDescriptionHtml} />
          {featured.data.artist && (
            <p class="text-sm text-black/50 mb-6">
              <span class="font-semibold">{t('work.artist')}:</span> {featured.data.artist}
            </p>
          )}
          <a
            href={getWorkPath(lang, featured.id)}
            class="brutal-btn brutal-btn-gold w-fit"
          >
            {t('home.featured.cta')} →
          </a>
        </div>
      </div>
    </div>
  </section>
)}
