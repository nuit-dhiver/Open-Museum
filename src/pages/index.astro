---
// Root entry point: detect visitor's preferred language and redirect.
// German (/de/) is the fallback default.
// True geo-based detection requires edge functions (not possible on GitHub Pages static hosting).
const site = 'https://openmuseum.io';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Open Museum — Redirecting…</title>

    <!-- SEO: canonical points to German home, x-default stays here -->
    <link rel="canonical" href={`${site}/de/`} />
    <link rel="alternate" hreflang="x-default" href={`${site}/`} />
    <link rel="alternate" hreflang="de" href={`${site}/de/`} />
    <link rel="alternate" hreflang="en" href={`${site}/en/`} />

    <!-- Fallback meta-refresh for bots/no-JS: go to German -->
    <meta http-equiv="refresh" content="0;url=/de/" />

    <script is:inline>
      // Client-side language detection based on browser preference
      (function () {
        var preferred = (navigator.language || navigator.languages?.[0] || 'de').toLowerCase();
        if (preferred.startsWith('en')) {
          window.location.replace('/en/');
        } else {
          window.location.replace('/de/');
        }
      })();
    </script>
  </head>
  <body>
    <p>
      Redirecting… / Weiterleitung…<br />
      <a href="/de/">Deutsch</a> · <a href="/en/">English</a>
    </p>
  </body>
</html>
