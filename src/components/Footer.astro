---
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="bg-black text-white border-t-[3px] border-brand-gold">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- About -->
      <div>
        <h3 class="font-heading text-lg font-bold text-brand-gold mb-4 uppercase">
          OPEN MUSEUM
        </h3>
        <p class="text-white/70 text-sm leading-relaxed">
          {t('footer.project')}
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading text-lg font-bold text-brand-gold mb-4 uppercase">
          {t('footer.contact')}
        </h3>
        <div class="space-y-2 text-sm text-white/70">
          <p>
            <span class="text-white font-semibold">{t('footer.address')}:</span><br />
            Göttingen, Niedersachsen, Deutschland
          </p>
          <p>
            <span class="text-white font-semibold">{t('footer.email')}:</span><br />
            <a href="mailto:info@goettingen-denkmale.de" class="hover:text-brand-gold transition-colors">
              alex@openmuseum.io
            </a>
          </p>
        </div>
      </div>

      <!-- Social Media -->
      <div>
        <h3 class="font-heading text-lg font-bold text-brand-gold mb-4 uppercase">
          {t('footer.social')}
        </h3>
        <div class="flex gap-4">
          <a
            href="https://www.linkedin.com/company/the-open-museum"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 border-2 border-white/30 flex items-center justify-center hover:border-brand-gold hover:text-brand-gold transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href="https://x.com/openmuseumio"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 border-2 border-white/30 flex items-center justify-center hover:border-brand-gold hover:text-brand-gold transition-colors"
            aria-label="X (Twitter)"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a
            href="https://github.com/nuit-dhiver/Open-Museum"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 border-2 border-white/30 flex items-center justify-center hover:border-brand-gold hover:text-brand-gold transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/openmuseum.goe"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 border-2 border-white/30 flex items-center justify-center hover:border-brand-gold hover:text-brand-gold transition-colors"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Sponsor -->
      <div>
        <h3 class="font-heading text-lg font-bold text-brand-gold mb-4 uppercase">
          {t('sponsor.title')}
        </h3>
        <p class="text-white/70 text-sm leading-relaxed mb-4">
          {t('sponsor.body')}
        </p>
        <a
          href="https://github.com/sponsors/nuit-dhiver"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 brutal-btn brutal-btn-gold text-sm px-4 py-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 21.593c-.425.53-.595.533-.598.533-.08 0-.224-.085-.457-.267C9.028 20.089 2 14.675 2 9a6 6 0 0111.015-3.36A6 6 0 0122 9c0 5.675-7.028 11.089-8.945 12.326-.234.182-.378.267-.457.267z"/>
          </svg>
          {t('sponsor.cta')}
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-8 border-t border-white/20 text-center text-sm text-white/50">
      <p>{t('footer.rights')}</p>
      <p class="mt-2 text-xs text-white/40 leading-relaxed max-w-4xl mx-auto">
        {t('footer.disclaimer')}
      </p>
      <p class="mt-2 text-xs text-white/40">
        {t('footer.takedownPolicy')}{' '}
        <a
          href="mailto:alex@openmuseum.io"
          class="underline hover:text-brand-gold transition-colors"
        >alex@openmuseum.io</a>
      </p>
    </div>
  </div>
</footer>
