---
import CityPage from '@/components/CityPage.astro';
import { getCollection } from 'astro:content';
import { cityNameToSlug } from '@/i18n/ui';

export async function getStaticPaths() {
  const works = await getCollection('works');
  const cityNames = [...new Set(works.map((w) => w.data.city).filter(Boolean))] as string[];
  return cityNames.map((cityName) => ({
    params: { city: cityNameToSlug(cityName) },
    props: { cityName },
  }));
}

interface Props {
  cityName: string;
}

const { cityName } = Astro.props;
---

<CityPage lang="de" cityName={cityName} />
