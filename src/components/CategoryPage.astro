---
import Base from '@/layouts/Base.astro';
import WorkCard from '@/components/WorkCard.astro';
import { useTranslations, type Lang, getCategoryPath, getWorkPath } from '@/i18n/ui';
import { getCollection } from 'astro:content';
import { getAssetUrl } from '@/utils/assets';

interface Props {
  lang: Lang;
  category: 'brunnen' | 'denkmal' | 'kunstwerk';
}

const { lang, category } = Astro.props;
const t = useTranslations(lang);

const categoryKey = `category.${category}` as const;
const categoryDescKey = `category.${category}.desc` as const;

const allWorks = await getCollection('works');
const works = allWorks.filter((w) => w.data.category === category);

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? '';

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: t(categoryKey),
  numberOfItems: works.length,
  itemListElement: works.map((work, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}${getWorkPath(lang, work.id)}`,
    name: work.data.title[lang],
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('nav.home'), item: `${siteUrl}/${lang}/` },
    { '@type': 'ListItem', position: 2, name: t(categoryKey) },
  ],
};
---

<Base title={`${t(categoryKey)} — Open Museum`} description={t(categoryDescKey)}>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <!-- Page header -->
  <section class="bg-black text-white py-12 sm:py-16 border-b-brutal border-brand-gold">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-4xl sm:text-5xl font-bold uppercase tracking-wider mb-3">
        {t(categoryKey)}
      </h1>
      <p class="text-white/70 text-lg">
        {t(categoryDescKey)}
      </p>
    </div>
  </section>

  <!-- Works grid -->
  <section class="py-12 sm:py-16 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {works.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {works.map((work) => (
            <WorkCard
              slug={work.id}
              title={work.data.title[lang]}
              poster={work.data.poster ? getAssetUrl(work.data.poster) : undefined}
              category={work.data.category}
              lang={lang}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-lg text-black/50 font-heading uppercase tracking-wider">
            {t('noworks')}
          </p>
        </div>
      )}
    </div>
  </section>
</Base>
