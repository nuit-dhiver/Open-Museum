---
import Base from '@/layouts/Base.astro';
import WorkCard from '@/components/WorkCard.astro';
import { useTranslations, type Lang, getWorkPath } from '@/i18n/ui';
import { getCollection } from 'astro:content';
import { getAssetUrl } from '@/utils/assets';

interface Props {
  lang: Lang;
  cityName: string;
}

const { lang, cityName } = Astro.props;
const t = useTranslations(lang);

const allWorks = await getCollection('works');
const works = allWorks.filter((w) => w.data.city === cityName);

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? '';

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: cityName,
  numberOfItems: works.length,
  itemListElement: works.map((work, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}${getWorkPath(lang, work.id)}`,
    name: work.data.title[lang],
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('nav.home'), item: lang === 'en' ? `${siteUrl}/en/` : `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: t('nav.cities'), item: lang === 'en' ? `${siteUrl}/en/cities/` : `${siteUrl}/staedte/` },
    { '@type': 'ListItem', position: 3, name: cityName },
  ],
};
---

<Base title={`${cityName} — Open Museum`} description={cityName}>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <!-- Page header -->
  <section class="bg-black text-white py-12 sm:py-16 border-b-brutal border-brand-gold">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-4xl sm:text-5xl font-bold uppercase tracking-wider mb-3">
        {cityName}
      </h1>
      <p class="text-white/70 text-lg">
        {works.length}
        {lang === 'de' ? 'Werke in dieser Stadt' : 'works in this city'}
      </p>
    </div>
  </section>

  <!-- Works grid -->
  <section class="py-12 sm:py-16 bg-off-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {works.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {works.map((work) => (
            <WorkCard
              slug={work.id}
              title={work.data.title[lang]}
              poster={work.data.poster ? getAssetUrl(work.data.poster) : undefined}
              category={work.data.category}
              lang={lang}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-lg text-black/50 font-heading uppercase tracking-wider">
            {t('noworks.city')}
          </p>
        </div>
      )}
    </div>
  </section>
</Base>
