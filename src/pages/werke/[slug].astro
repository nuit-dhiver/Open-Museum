---
import StaticRedirect from '@/components/StaticRedirect.astro';
import { getCollection } from 'astro:content';
import { getLegacyWorkRedirect } from '@/data/legacy-url-redirects';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((work) => ({
    params: { slug: work.id },
    props: { to: getLegacyWorkRedirect('de', work.id) },
  }));
}

interface Props {
  to: string;
}

const { to } = Astro.props;
---

<StaticRedirect to={to} />
