---
// SEO redirect: /staedte/{city}/ → /de/cities/{city}/
import { getCollection } from 'astro:content';
import { cityNameToSlug } from '@/i18n/ui';

export async function getStaticPaths() {
  const works = await getCollection('works');
  const cityNames = [...new Set(works.map((w) => w.data.city).filter(Boolean))] as string[];
  return cityNames.map((cityName) => ({
    params: { city: cityNameToSlug(cityName) },
    props: { city: cityNameToSlug(cityName) },
  }));
}

interface Props { city: string; }
const { city } = Astro.props;
const newUrl = `/de/cities/${city}/`;
const canonicalHref = `https://openmuseum.io/de/cities/${city}/`;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting…</title>
    <link rel="canonical" href={canonicalHref} />
    <meta http-equiv="refresh" content={`0;url=${newUrl}`} />
  </head>
  <body>
    <p>Weiterleitung… <a href={newUrl}>{newUrl}</a></p>
  </body>
</html>
