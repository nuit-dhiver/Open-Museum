---
import Base from '@/layouts/Base.astro';
import ModelViewer from '@/components/ModelViewer.astro';
import { useTranslations, getCategoryPath, getWorkPath, type Lang } from '@/i18n/ui';
import { marked } from 'marked';
import { getAssetUrl } from '@/utils/assets';

interface Props {
  work: any;
  lang: Lang;
}

const { work, lang } = Astro.props;
const t = useTranslations(lang);
const { data } = work;
const category = data.category as 'brunnen' | 'denkmal' | 'kunstwerk';

const categoryKey = `category.${category}` as const;
const descriptionHtml = await marked.parse(data.description[lang]);
const shareDescription = data.description[lang].replace(/[#*_`>\n]/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 180);

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? '';
const homePath = `${import.meta.env.BASE_URL}${lang}/`;
const workUrl = `${siteUrl}${getWorkPath(lang, work.id)}`;
const categoryUrl = `${siteUrl}${getCategoryPath(lang, category)}`;
const licenseUrl = lang === 'de'
  ? 'https://creativecommons.org/licenses/by-nc/4.0/deed.de'
  : 'https://creativecommons.org/licenses/by-nc/4.0/';

const visualArtworkSchema = {
  '@context': 'https://schema.org',
  '@type': 'VisualArtwork',
  name: data.title[lang],
  ...(data.artist && { creator: { '@type': 'Person', name: data.artist } }),
  ...(data.year && { dateCreated: data.year }),
  ...(data.material && { artMedium: data.material[lang] }),
  ...(data.description[lang] && { description: data.description[lang] }),
  ...(data.poster && { image: `${siteUrl}${getAssetUrl(data.poster)}` }),
  ...(data.location.address && {
    locationCreated: {
      '@type': 'Place',
      name: data.location.address,
      geo: { '@type': 'GeoCoordinates', latitude: data.location.lat, longitude: data.location.lng },
    },
  }),
  url: workUrl,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('nav.home'), item: `${siteUrl}${homePath}` },
    { '@type': 'ListItem', position: 2, name: t(categoryKey), item: categoryUrl },
    { '@type': 'ListItem', position: 3, name: data.title[lang] },
  ],
};
---

<Base title={`${data.title[lang]} — Open Museum`} description={data.description[lang]} ogImage={data.poster ? getAssetUrl(data.poster) : undefined}>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(visualArtworkSchema)} />
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <div class="bg-off-white border-b-brutal border-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm font-heading uppercase tracking-wider">
        <a href={homePath} class="hover:text-brand-gold transition-colors">{t('nav.home')}</a>
        <span class="text-black/30">→</span>
        <a href={getCategoryPath(lang, data.category)} class="hover:text-brand-gold transition-colors">
          {t(categoryKey)}
        </a>
        <span class="text-black/30">→</span>
        <span class="text-black/50">{data.title[lang]}</span>
      </nav>
    </div>
  </div>

  <section class="bg-black text-white py-8 sm:py-12 border-b-brutal border-brand-gold">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl sm:text-5xl font-bold uppercase tracking-wider">
        {data.title[lang]}
      </h1>
      {data.artist && (
        <p class="mt-2 text-white/60 text-lg">
          {t('work.artist')}: {data.artist}{data.year ? ` · ${data.year}` : ''}
        </p>
      )}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-8">
        {data.model.glb && (
          <div>
            <h2 class="font-heading text-xl font-bold uppercase tracking-wider mb-4">
              {t('work.view3d')}
            </h2>
            <div class="aspect-square">
              <ModelViewer
                src={getAssetUrl(data.model.glb)}
                iosSrc={data.model.usdz ? getAssetUrl(data.model.usdz) : undefined}
                alt={data.title[lang]}
                poster={data.poster ? getAssetUrl(data.poster) : undefined}
                class="h-full"
              />
            </div>
            <div class="mt-4 flex flex-col sm:flex-row gap-3 sm:items-stretch" id="social-share" data-share-url={workUrl} data-share-title={data.title[lang]} data-share-description={shareDescription} data-share-copied-message={t('work.shareCopied')}>
              <button id="download-btn" class="brutal-btn brutal-btn-black flex-1 justify-center">
                {t('work.download')}
              </button>
              <button id="share-btn" class="brutal-btn brutal-btn-black justify-center sm:w-auto" aria-label={t('work.share')}>
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="18" cy="5" r="3"></circle>
                  <circle cx="6" cy="12" r="3"></circle>
                  <circle cx="18" cy="19" r="3"></circle>
                  <path d="M8.59 13.51l6.83 3.98"></path>
                  <path d="M15.41 6.51L8.59 10.49"></path>
                </svg>
                <span>{t('work.share')}</span>
              </button>
            </div>
          </div>
        )}

        {data.photos.length > 0 && (
          <div>
            <h2 class="font-heading text-xl font-bold uppercase tracking-wider mb-4">
              {t('work.photos')}
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {data.photos.map((photo: string) => (
                <div class="brutal-card overflow-hidden aspect-square">
                  <img src={getAssetUrl(photo)} alt={data.title[lang]} class="w-full h-full object-cover cursor-pointer photo-gallery-thumb" data-full={getAssetUrl(photo)} loading="lazy" />
                </div>
              ))}
            </div>
          </div>
        )}

        <div id="photo-lightbox" class="photo-lightbox" aria-hidden="true">
          <button class="photo-lightbox-close" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
          <img class="photo-lightbox-img" src="" alt="" />
        </div>

        <div class="prose" set:html={descriptionHtml} />
      </div>

      {data.model.glb && (
        <div id="license-modal" class="license-modal" aria-hidden="true">
          <div class="license-modal-card">
            <h3>{t('work.licenseTitle')}</h3>
            <p>
              {t('work.licenseNotice')}{' '}
              <a href={licenseUrl} target="_blank" rel="noopener noreferrer">
                {t('work.licenseLink')}
              </a>{' '}
              {t('work.licenseNoticeAfter')}
            </p>
            <p class="license-modal-hint">{t('work.licenseDownloadWith')}</p>
            <div class="mt-2 flex flex-col gap-3">
              <button id="download-glb" class="brutal-btn brutal-btn-black w-full justify-center" data-href={getAssetUrl(data.model.glb)} data-filename={`${work.id}.glb`}>
                {t('work.downloadGLB')}
              </button>
              {data.model.usdz && (
                <button id="download-usdz" class="brutal-btn brutal-btn-black w-full justify-center" data-href={getAssetUrl(data.model.usdz)} data-filename={`${work.id}.usdz`}>
                  {t('work.downloadUSDZ')}
                </button>
              )}
            </div>
          </div>
        </div>
      )}

      {data.model.glb && (
        <div id="share-modal" class="license-modal" aria-hidden="true">
          <div class="license-modal-card">
            <h3>{t('work.share')}</h3>
            <p class="license-modal-hint">{t('work.shareWith')}</p>
            <div class="mt-2 flex flex-col gap-3">
              <button id="share-copy-link" class="brutal-btn brutal-btn-black w-full justify-center" aria-label={t('work.shareCopyLink')} title={t('work.shareCopyLink')}>
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 13a5 5 0 0 0 7.07 0l2.83-2.83a5 5 0 0 0-7.07-7.07L11 4"></path>
                  <path d="M14 11a5 5 0 0 0-7.07 0L4.1 13.83a5 5 0 0 0 7.07 7.07L13 19"></path>
                </svg>
                <span>{t('work.shareCopyLink')}</span>
              </button>
              <button id="share-twitter" class="brutal-btn brutal-btn-black w-full justify-center" aria-label={t('work.shareTwitter')} title={t('work.shareTwitter')}>
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4l16 16" />
                  <path d="M20 4L4 20" />
                </svg>
                <span>{t('work.shareTwitter')}</span>
              </button>
              <button id="share-facebook" class="brutal-btn brutal-btn-black w-full justify-center" aria-label={t('work.shareFacebook')} title={t('work.shareFacebook')}>
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M14.5 8H17V4h-2.5C10.9 4 9 6.2 9 9.6V12H6v4h3v4h4v-4h3l1-4h-4V9.9c0-1.2.4-1.9 1.5-1.9z" />
                </svg>
                <span>{t('work.shareFacebook')}</span>
              </button>
              <button id="share-instagram" class="brutal-btn brutal-btn-black w-full justify-center" aria-label={t('work.shareInstagram')} title={t('work.shareInstagram')}>
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
                  <circle cx="12" cy="12" r="4"></circle>
                  <circle cx="17.5" cy="6.5" r="1"></circle>
                </svg>
                <span>{t('work.shareInstagram')}</span>
              </button>
            </div>
          </div>
        </div>
      )}

      <aside class="space-y-6">
        <div class="brutal-card p-6">
          <h3 class="font-heading text-lg font-bold uppercase tracking-wider mb-4 border-b-brutal border-black pb-2">
            Info
          </h3>
          <dl class="space-y-3 text-sm">
            {data.artist && (
              <div>
                <dt class="font-semibold uppercase tracking-wider text-black/50">{t('work.artist')}</dt>
                <dd class="mt-0.5">{data.artist}</dd>
              </div>
            )}
            {data.year && (
              <div>
                <dt class="font-semibold uppercase tracking-wider text-black/50">{t('work.year')}</dt>
                <dd class="mt-0.5">{data.year}</dd>
              </div>
            )}
            {data.material && (
              <div>
                <dt class="font-semibold uppercase tracking-wider text-black/50">{t('work.material')}</dt>
                <dd class="mt-0.5">{data.material[lang]}</dd>
              </div>
            )}
            {data.location.address && (
              <div>
                <dt class="font-semibold uppercase tracking-wider text-black/50">{t('work.location')}</dt>
                <dd class="mt-0.5">{data.location.address}</dd>
              </div>
            )}
            {data.modelCreator && (
              <div>
                <dt class="font-semibold uppercase tracking-wider text-black/50">{t('work.modelCreator')}</dt>
                <dd class="mt-0.5">{data.modelCreator}</dd>
              </div>
            )}
          </dl>
        </div>

        {data.location.myMapsEmbedUrl ? (
          <div class="brutal-card overflow-hidden">
            <h3 class="font-heading text-lg font-bold uppercase tracking-wider p-4 border-b-brutal border-black">
              {t('work.location')}
            </h3>
            <iframe
              src={data.location.myMapsEmbedUrl}
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        ) : (
          <div class="brutal-card overflow-hidden">
            <h3 class="font-heading text-lg font-bold uppercase tracking-wider p-4 border-b-brutal border-black">
              {t('work.location')}
            </h3>
            <iframe
              src={`https://www.google.com/maps?q=${data.location.lat},${data.location.lng}&z=16&output=embed`}
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        )}

        <a href={getCategoryPath(lang, category)} class="brutal-btn brutal-btn-black w-full justify-center">
          ← {t('work.back')}
        </a>
      </aside>
    </div>
  </div>

  <script>
    function initLightbox() {
      const lightbox = document.getElementById('photo-lightbox');
      const lightboxImg = lightbox?.querySelector('.photo-lightbox-img') as HTMLImageElement | null;
      const closeBtn = lightbox?.querySelector('.photo-lightbox-close');
      if (!lightbox || !lightboxImg) return;

      document.querySelectorAll('.photo-gallery-thumb').forEach((thumb) => {
        thumb.addEventListener('click', () => {
          const src = (thumb as HTMLElement).dataset.full || (thumb as HTMLImageElement).src;
          const alt = (thumb as HTMLImageElement).alt || '';
          lightboxImg.src = src;
          lightboxImg.alt = alt;
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        });
      });

      closeBtn?.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) closeLightbox();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && lightbox.getAttribute('aria-hidden') === 'false') closeLightbox();
      });

      function closeLightbox() {
        lightbox!.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLightbox);
    } else {
      initLightbox();
    }

    const downloadBtn = document.getElementById('download-btn');
    const downloadGlb = document.getElementById('download-glb');
    const downloadUsdz = document.getElementById('download-usdz');
    const licenseModal = document.getElementById('license-modal');
    const shareBtn = document.getElementById('share-btn');
    const shareModal = document.getElementById('share-modal');
    const socialShare = document.getElementById('social-share');
    const shareCopyLink = document.getElementById('share-copy-link');
    const shareTwitter = document.getElementById('share-twitter');
    const shareFacebook = document.getElementById('share-facebook');
    const shareInstagram = document.getElementById('share-instagram');

    function openLicenseModal() {
      licenseModal?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLicenseModal() {
      licenseModal?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function openShareModal() {
      shareModal?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeShareModal() {
      shareModal?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    downloadBtn?.addEventListener('click', openLicenseModal);
    shareBtn?.addEventListener('click', openShareModal);

    licenseModal?.addEventListener('click', (e) => {
      if (e.target === licenseModal) closeLicenseModal();
    });

    shareModal?.addEventListener('click', (e) => {
      if (e.target === shareModal) closeShareModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && licenseModal?.getAttribute('aria-hidden') === 'false') {
        closeLicenseModal();
      }
      if (e.key === 'Escape' && shareModal?.getAttribute('aria-hidden') === 'false') {
        closeShareModal();
      }
    });

    function createDownloadLink(href: string, filename: string) {
      const link = document.createElement('a');
      link.href = href;
      link.download = filename;
      link.target = '_blank';
      link.rel = 'noopener noreferrer';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    if (downloadGlb) {
      downloadGlb.addEventListener('click', () => {
        if (downloadGlb.dataset.href && downloadGlb.dataset.filename) {
          createDownloadLink(downloadGlb.dataset.href, downloadGlb.dataset.filename);
        }
      });
    }

    if (downloadUsdz) {
      downloadUsdz.addEventListener('click', () => {
        if (downloadUsdz.dataset.href && downloadUsdz.dataset.filename) {
          createDownloadLink(downloadUsdz.dataset.href, downloadUsdz.dataset.filename);
        }
      });
    }

    function getCanonicalShareUrl() {
      const initial = socialShare?.getAttribute('data-share-url') || window.location.href;
      const url = new URL(initial, window.location.origin);
      url.hash = '';
      url.search = '';
      return url.toString();
    }

    function getSharePageUrl(source: 'twitter' | 'facebook' | 'instagram') {
      const shareUrl = new URL(getCanonicalShareUrl());
      shareUrl.searchParams.set('utm_source', source);
      shareUrl.searchParams.set('utm_medium', 'social');
      shareUrl.searchParams.set('utm_campaign', 'model_share');
      return shareUrl.toString();
    }

    function getShareText() {
      const title = socialShare?.getAttribute('data-share-title') || document.title;
      const description = socialShare?.getAttribute('data-share-description') || '';
      return description ? `${title} - ${description}` : title;
    }

    function openShareWindow(url: string) {
      window.open(url, '_blank', 'noopener,noreferrer');
    }

    async function copyTextToClipboard(text: string) {
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return true;
        }
      } catch {
        // Fallback below when Clipboard API is blocked.
      }

      const helper = document.createElement('textarea');
      helper.value = text;
      helper.setAttribute('readonly', '');
      helper.style.position = 'absolute';
      helper.style.left = '-9999px';
      document.body.appendChild(helper);
      helper.select();
      const copied = document.execCommand('copy');
      document.body.removeChild(helper);
      return copied;
    }

    shareTwitter?.addEventListener('click', () => {
      const url = getSharePageUrl('twitter');
      const text = getShareText();
      openShareWindow(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`);
      closeShareModal();
    });

    shareCopyLink?.addEventListener('click', async () => {
      const url = getCanonicalShareUrl();
      const copiedMessage = socialShare?.getAttribute('data-share-copied-message') || 'Link copied.';
      await copyTextToClipboard(url);
      alert(copiedMessage);
      closeShareModal();
    });

    shareFacebook?.addEventListener('click', () => {
      const url = getSharePageUrl('facebook');
      openShareWindow(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`);
      closeShareModal();
    });

    shareInstagram?.addEventListener('click', async () => {
      const url = getSharePageUrl('instagram');
      const title = socialShare?.getAttribute('data-share-title') || document.title;
      const description = socialShare?.getAttribute('data-share-description') || '';
      const shareCopy = description ? `${title}\n${description}\n${url}` : `${title}\n${url}`;
      const copiedMessage = socialShare?.getAttribute('data-share-copied-message') || 'Link copied.';
      await copyTextToClipboard(shareCopy);
      alert(copiedMessage);
      openShareWindow('https://www.instagram.com/');
      closeShareModal();
    });
  </script>
</Base>
