---
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props {
  src: string;
  iosSrc?: string;
  alt: string;
  poster?: string;
  class?: string;
  tour?: any[];
  lang?: string;
}

const { src, iosSrc, alt, poster, class: className = '', tour, lang = 'en' } = Astro.props;
const t = useTranslations(lang as Lang);
---

<div 
  class={`brutal-card overflow-hidden model-viewer-container ${className}`}
  data-tour={tour ? JSON.stringify(tour) : undefined}
  data-tour-lang={lang}
>
  <!-- Use data-attributes instead of direct src/ios-src to prevent unauthenticated direct loads -->
  <model-viewer
    data-src={src}
    data-ios-src={iosSrc}
    alt={alt}
    poster={poster}
    camera-controls
    auto-rotate
    auto-rotate-delay="1000"
    shadow-intensity="1"
    ar
    ar-modes="webxr scene-viewer quick-look"
    loading="lazy"
    style="width: 100%; height: 100%;"
  >
    <div class="absolute inset-0 flex items-center justify-center bg-off-white" slot="poster">
      {poster ? (
        <img src={poster} alt={alt} class="w-full h-full object-cover" />
      ) : (
        <div class="text-center">
          <div class="animate-spin w-8 h-8 border-4 border-black border-t-brand-gold rounded-full mx-auto mb-2"></div>
          <p class="font-heading text-sm uppercase tracking-wider">Loading 3D…</p>
        </div>
      )}
    </div>
  </model-viewer>

  <!-- Secure 3D loading indicator -->
  <div
    id="secure-loader-badge"
    class="absolute top-4 left-4 z-20 brutal-card bg-brand-gold font-heading text-xs uppercase tracking-wider px-3 py-1.5 border-2 border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] flex items-center gap-2 transition-all duration-300 pointer-events-none font-bold"
    style="display: none;"
  >
    <span class="animate-spin w-3.5 h-3.5 border-2 border-black border-t-transparent rounded-full inline-block"></span>
    <span id="secure-loader-text">Connecting…</span>
  </div>

  <button class="fullscreen-btn" aria-label="Toggle fullscreen" title="Fullscreen">
    <!-- Expand icon -->
    <svg class="icon-expand" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 3 21 3 21 9"></polyline>
      <polyline points="9 21 3 21 3 15"></polyline>
      <line x1="21" y1="3" x2="14" y2="10"></line>
      <line x1="3" y1="21" x2="10" y2="14"></line>
    </svg>
    <!-- Compress icon -->
    <svg class="icon-compress" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="4 14 10 14 10 20"></polyline>
      <polyline points="20 10 14 10 14 4"></polyline>
      <line x1="14" y1="10" x2="21" y2="3"></line>
      <line x1="3" y1="21" x2="10" y2="14"></line>
    </svg>
  </button>

  {tour && tour.length > 0 && (
    <button class="tour-play-btn brutal-btn brutal-btn-gold absolute bottom-4 left-4 z-10" aria-label={t('tour.play')}>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <polygon points="5 3 19 12 5 21 5 3"></polygon>
      </svg>
      <span>{t('tour.play')}</span>
    </button>
  )}
</div>

<style>
  .model-viewer-container {
    position: relative;
  }

  /* Hide on mobile — native AR/VR views already provide fullscreen */
  .fullscreen-btn {
    position: absolute;
    bottom: 12px;
    right: 12px;
    z-index: 10;
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(0, 0, 0, 0.65);
    color: #fff;
    border: 2px solid #000;
    border-radius: 6px;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .fullscreen-btn:hover {
    background: rgba(0, 0, 0, 0.85);
    transform: translateY(-1px);
  }

  .fullscreen-btn:active {
    transform: translateY(1px);
  }

  /* Show fullscreen button only on non-touch / desktop devices */
  @media (hover: hover) and (pointer: fine) {
    .fullscreen-btn {
      display: flex;
    }
  }

  .fullscreen-btn .icon-compress {
    display: none;
  }

  /* When the container is fullscreen, swap icons and adjust layout */
  .model-viewer-container:fullscreen {
    width: 100vw;
    height: 100vh;
    border: none;
    box-shadow: none;
    border-radius: 0;
    background: #000;
  }

  .model-viewer-container:fullscreen .icon-expand {
    display: none;
  }

  .model-viewer-container:fullscreen .icon-compress {
    display: block;
  }

  /* Safari */
  .model-viewer-container:-webkit-full-screen {
    width: 100vw;
    height: 100vh;
    border: none;
    box-shadow: none;
    border-radius: 0;
    background: #000;
  }

  .model-viewer-container:-webkit-full-screen .icon-expand {
    display: none;
  }

  .model-viewer-container:-webkit-full-screen .icon-compress {
    display: block;
  }
</style>

<script>
  function initFullscreenButtons() {
    document.querySelectorAll('.model-viewer-container').forEach((container) => {
      const btn = container.querySelector('.fullscreen-btn');
      if (!btn || btn.hasAttribute('data-fs-init')) return;
      btn.setAttribute('data-fs-init', '');

      btn.addEventListener('click', () => {
        const fsElement = document.fullscreenElement || (document as any).webkitFullscreenElement;
        if (!fsElement) {
          if (container.requestFullscreen) {
            container.requestFullscreen();
          } else if ((container as any).webkitRequestFullscreen) {
            (container as any).webkitRequestFullscreen();
          }
        } else {
          if (document.exitFullscreen) {
            document.exitFullscreen();
          } else if ((document as any).webkitExitFullscreen) {
            (document as any).webkitExitFullscreen();
          }
        }
      });
    });
  }

  function initUIBlockers() {
    document.querySelectorAll('.model-viewer-container').forEach((container) => {
      if (container.hasAttribute('data-blockers-init')) return;
      container.setAttribute('data-blockers-init', '');

      // Prevent context menus (right-clicks) on the 3D container
      container.addEventListener('contextmenu', (e) => {
        e.preventDefault();
        return false;
      });

      // Prevent dragging of any internal elements (posters, banners, etc.)
      container.addEventListener('dragstart', (e) => {
        e.preventDefault();
        return false;
      });
    });
  }

  async function initSecureModelViewer() {
    const containers = document.querySelectorAll('.model-viewer-container');
    
    for (const container of containers) {
      const viewer = container.querySelector('model-viewer');
      if (!viewer) continue;

      // If the viewer has been initialized but the src is a revoked blob URL,
      // reset it to allow a fresh authenticated fetch on re-entry (e.g., from bfcache).
      if (viewer.hasAttribute('data-initialized')) {
        const currentSrc = viewer.getAttribute('src');
        if (currentSrc && currentSrc.startsWith('blob:')) {
          viewer.removeAttribute('data-initialized');
          viewer.removeAttribute('src');
          viewer.removeAttribute('ios-src');
        }
      }

      if (viewer.hasAttribute('data-initialized')) continue;
      viewer.setAttribute('data-initialized', 'true');

      const src = viewer.getAttribute('data-src');
      const iosSrc = viewer.getAttribute('data-ios-src');
      
      const badge = container.querySelector('#secure-loader-badge') as HTMLElement;
      const loaderText = container.querySelector('#secure-loader-text') as HTMLElement;
      
      if (!src) continue;

      try {
        // Dynamically import the client-side Firebase logic to keep initial page load fast
        const { isFirebaseConfigured, fetchSecureModel } = await import('@/utils/firebase-client');
        
        if (isFirebaseConfigured) {
          if (badge) badge.style.display = 'flex';
          if (loaderText) loaderText.textContent = 'Securing Session…';

          // Securely load the GLB model file using credentials
          const secureSrc = await fetchSecureModel(src);
          viewer.setAttribute('src', secureSrc);
          
          // Temporary internal array of URLs we need to revoke once loading is done
          const urlsToRevoke = [secureSrc];

          // Securely load the USDZ file if present
          if (iosSrc) {
            if (loaderText) loaderText.textContent = 'Securing AR View…';
            const secureIosSrc = await fetchSecureModel(iosSrc);
            viewer.setAttribute('ios-src', secureIosSrc);
            urlsToRevoke.push(secureIosSrc);
          }

          // Trigger automatic Object URL revocation once `<model-viewer>` is fully loaded in GPU memory
          viewer.addEventListener('load', () => {
            urlsToRevoke.forEach((url) => {
              try {
                URL.revokeObjectURL(url);
              } catch (e) {
                console.warn('Object URL revocation failed or was already revoked:', e);
              }
            });
          }, { once: true });

          // Smoothly remove the loading badge
          if (badge) {
            badge.style.transform = 'scale(0.9)';
            badge.style.opacity = '0';
            setTimeout(() => badge.remove(), 300);
          }
        } else {
          // Fallback to direct loading when Firebase config is missing (local dev)
          viewer.setAttribute('src', src);
          if (iosSrc) viewer.setAttribute('ios-src', iosSrc);
        }
      } catch (error) {
        console.error('Secure 3D model rendering failed, falling back to direct URL:', error);
        // Graceful fail-safe fallback
        viewer.setAttribute('src', src);
        if (iosSrc) viewer.setAttribute('ios-src', iosSrc);
        if (badge) badge.remove();
      }
    }
  }

  import { initTourController } from '@/utils/tour-controller';

  function setup() {
    initFullscreenButtons();
    initUIBlockers();
    initSecureModelViewer();
    initTourController();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }

  // Support Astro view transitions or dynamic route loads if needed
  document.addEventListener('astro:page-load', setup);

  // Clean up DOM attributes before Astro swaps page contents (View Transitions support)
  document.addEventListener('astro:before-swap', () => {
    document.querySelectorAll('model-viewer').forEach((viewer) => {
      viewer.removeAttribute('data-initialized');
      viewer.removeAttribute('src');
      viewer.removeAttribute('ios-src');
    });
  });

  // Handle browser back/forward cache (bfcache) restores
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      document.querySelectorAll('.model-viewer-container').forEach((container) => {
        const viewer = container.querySelector('model-viewer');
        if (viewer) {
          viewer.removeAttribute('data-initialized');
          viewer.removeAttribute('src');
          viewer.removeAttribute('ios-src');
        }
      });
      setup();
    }
  });
</script>
